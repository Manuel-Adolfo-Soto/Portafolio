generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  password      String?
  image         String?
  role          String   @default("user") // user | admin
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile        Profile?
  recommendations Recommendation[]
  favorites      Favorite[]
  notifications  Notification[]
  auditLogs      AuditLog[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  title           String?
  career          String?
  yearsExperience Float?
  modality        String?  // remote, hybrid, onsite
  country         String?
  city            String?
  summary         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       ProfileSkill[]
  languages    Language[]
  certificates Certificate[]
  resumes      Resume[]
}

model ProfileSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String
  level     String @default("intermediate") // beginner, intermediate, advanced

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String // frontend, backend, database, tool, language

  profiles ProfileSkill[]
}

model Language {
  id        String @id @default(cuid())
  profileId String
  name      String
  level     String // basic, intermediate, advanced, native

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Certificate {
  id        String @id @default(cuid())
  profileId String
  name      String
  issuer    String
  date      String?
  url       String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Resume {
  id         String @id @default(cuid())
  profileId  String
  fileUrl    String
  parsedData String? // JSON
  createdAt  DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Job {
  id          String   @id @default(cuid())
  externalId  String?
  title       String
  company     String
  description String?
  location    String?
  modality    String?  // remote, hybrid, onsite, unknown
  salaryMin   Float?
  salaryMax   Float?
  currency    String?
  country     String?
  skillsRaw   String?  // JSON array of skill names
  source      String   // remoteok, wellfound, greenhouse, lever
  url         String
  logoUrl     String?
  postedAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recommendations Recommendation[]
  favorites      Favorite[]

  @@unique([source, externalId])
  @@index([createdAt])
  @@index([source])
  @@index([title])
  @@index([country])
  @@index([modality])
}

model JobProvider {
  id        String    @id @default(cuid())
  name      String    @unique
  baseUrl   String
  active    Boolean   @default(true)
  lastRunAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Recommendation {
  id             String   @id @default(cuid())
  userId         String
  jobId          String
  score          Float
  scoreBreakdown String?  // JSON
  seen           Boolean  @default(false)
  applied        Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, score])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // email, telegram, discord
  channel   String   // email, telegram, discord
  minScore  Float    @default(80)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
